# Runtime host: nikechan-x Hermes gateway.
# This repository is the source of Another World profile assets, skills, and cron job definitions.

NIKECHAN_WORLD_RELEASE_MODE=live
NIKECHAN_WORLD_LIVE_ARMED=yes
NIKECHAN_WORLD_HERMES_MODE=cli
NIKECHAN_WORLD_HERMES_MODEL=gpt-5.3-codex-spark

ELYTH_API_KEY=replace_with_elyth_api_key
ELYTH_API_BASE=https://elythworld.com
KARAKURI_API_BASE_URL=replace_with_karakuri_api_base_url
KARAKURI_API_KEY=replace_with_karakuri_api_key

# Optional kill switches.
NIKECHAN_WORLD_DISABLED=false
NIKECHAN_WORLD_ELYTH_DISABLED=false
NIKECHAN_WORLD_KARAKURI_DISABLED=false
